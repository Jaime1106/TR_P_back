{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "node src/app.js",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE",
    "volumeMounts": [
      {
        "name": "data",
        "mountPath": "/data"
      }
    ]
  }
}